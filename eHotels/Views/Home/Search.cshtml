@{
    ViewData["Title"] = "Search";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eHotels</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/searchBar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/form.css" asp-append-version="true" />
</head>

<body>

    <div class="form-overlay" style="display: none;">
        <form class="form-container" action="CreateBooking" method="post">
            <button type="button" class="close-button">X</button>
            <div class="form-title">Booking Information</div>
            <div class="line-break"></div>
            <div class="booking-hotel-info">Hotel Name, Room capacity, View</div>

            <input class="hotel-id-input-holder" name="hotelId" type="number" value=0 style="display: none;" />
            <input class="room-number-input-holder" name="roomNumber" type="number" value=0 style="display: none;" />

            <select name="idType" class="id-select">
                <option selected>choose id Type</option>
                <option>SSN</option>
                <option>Drivers License</option>
                <option>Passport</option>
            </select>

            <input name="idNumber" type="text" placeholder="ID Number"/>
            <input name="firstName" type="text" placeholder="First Name"/>
            <input name="lastName" type="text" placeholder="Last Name"/>

            <div class="inline-inputs" style="grid-template-columns: 1fr 1fr;">
                <input name="streetNumber" type="number" placeholder="street number"/>
                <input name="streetName" type="text" placeholder="street name"/>
                <input name="city" type="text" placeholder="city"/>
                <input name="province" type="text" placeholder="province"/>
                <input name="country" type="text" placeholder="country"/>
                <input name="postalCode" type="text" placeholder="postal code"/>
            </div>

            <div class="inline-inputs" style="grid-template-columns: 1fr 1fr;">
                <input name="startDate" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" name="startDate" placeholder="Start Date" value="@Context.Request.Query["startDate"]"/>
                <input name="endDate" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" name="endDate" placeholder="End Date" value="@Context.Request.Query["endDate"]"/>
            </div>

            <input name="phoneNumber" type="text" placeholder="Phone number"/>
            <button type="submit" class="submit-button">Book!</button>
        </form>
    </div>

    <div class="search-bar">
        <form id="search-form" action="/Home/Search" method="get">
            <input class="hotel-search" type="text" name="search" placeholder="Search Hotel Chain..." value="@Context.Request.Query["search"]"/>
            <input class="area" type="text" name="area" placeholder="Area" value="@Context.Request.Query["area"]"/>
            <input class="capacity" type="number" name="capacity" placeholder="Capacity" value="@Context.Request.Query["capacity"]"/>
            <input class="start-date" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" name="startDate" placeholder="Start Date" value="@Context.Request.Query["startDate"]"/>
            <input class="end-date" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" name="endDate" placeholder="End Date" value="@Context.Request.Query["endDate"]"/>
            <button class="submit">
                <img class="search-img" src="https://static.vecteezy.com/system/resources/thumbnails/009/652/218/small/magnifying-glass-icon-isolated-on-white-background-search-illustration-vector.jpg" />
            </button>
        </form>
    </div>

    <div class="filters-holder">
        <div class="filters-title">Filters:</div>

        <div class="select-holder">
            <div class="select-title">Rating:</div>
            <select name="stars" form="search-form" class="option-select">
                <option value=0 selected="@(Context.Request.Query["stars"] == "0" ? "selected" : null)">Any</option>
                <option value=1 selected="@(Context.Request.Query["stars"] == "1" ? "selected" : null)">1⭐</option>
                <option value=2 selected="@(Context.Request.Query["stars"] == "2" ? "selected" : null)">2⭐</option>
                <option value=3 selected="@(Context.Request.Query["stars"] == "3" ? "selected" : null)">3⭐</option>
                <option value=4 selected="@(Context.Request.Query["stars"] == "4" ? "selected" : null)">4⭐</option>
                <option value=5 selected="@(Context.Request.Query["stars"] == "5" ? "selected" : null)">5⭐</option>
            </select>
        </div>

        <div class="select-holder">
            <div class="select-title">View:</div>
            <select name="view" form="search-form" class="option-select">
                <option value="ANY" selected="@(Context.Request.Query["view"] == "ANY" ? "selected" : null)">Any</option>
                <option selected="@(Context.Request.Query["view"] == "Sea" ? "selected" : null)">Sea</option>
                <option selected="@(Context.Request.Query["view"] == "Beach Front" ? "selected" : null)">Beach Front</option>
                <option selected="@(Context.Request.Query["view"] == "Garden" ? "selected" : null)">Garden</option>
                <option selected="@(Context.Request.Query["view"] == "City" ? "selected" : null)">City</option>
            </select>
        </div>

        <div class="select-holder">
            <div class="select-title">Price Range:</div>
            <input name="minPrice" form="search-form" value="@Context.Request.Query["minPrice"]" class="price-input" min="1" max="999" type="number" placeholder="min"/>
            -
            <input name="maxPrice" form="search-form" value="@Context.Request.Query["maxPrice"]" class="price-input" min="1" max="999" type="number" placeholder="max"/>
        </div>

        <div class="select-holder">
            <div class="select-title">Total Rooms:</div>
            <input name="minRoomCount" form="search-form" value="@Context.Request.Query["minRoomCount"]" class="rooms-input" min="1" max="10000" type="number" placeholder="min"/>
            -
            <input name="maxRoomCount" form="search-form" value="@Context.Request.Query["maxRoomCount"]" class="rooms-input" min="1" max="10000" type="number" placeholder="max"/>
        </div>

        <div class="select-holder">
            <div class="select-title">Sort:</div>
            <select class="option-select">
                <option selected>Default</option>
                <option>Price</option>
                <option>Name</option>
                <option>Stars</option>
            </select>
        </div>

    </div>

    <div class="results-holder">
        @foreach (var roomInfo in ViewBag.availableRooms){
            <div class="search-result" hotel-name=@(roomInfo.name) capacity=@(roomInfo.capacity)  hotel-id=@(roomInfo.hotelid) room-number=@(roomInfo.roomnumber) price=@(roomInfo.price)>
                <img class="hotel-image" src="https://t3.ftcdn.net/jpg/10/22/24/80/360_F_1022248039_7LDxHRi3Mlt9BK3wzLBUGZp9XAO1gt2s.jpg" />
                <div class="info-holder">
                    <div class="main-info">
                        <div class="hotel-name">@roomInfo.name</div>
                        <div class="stars">@roomInfo.stars ⭐</div>
                        <div class="price-range">@roomInfo.price$ / day</div>
                    </div>

                    <div class="line-break"></div>

                    <div class="result-body-holder">
                        <div class="other-info">
                            <div class="address">Address: @roomInfo.streetnum, @roomInfo.streetname, @roomInfo.city, @roomInfo.province, @roomInfo.country, @roomInfo.postalcode</div>
                            <div class="total-capacity-chain">Total Rooms in hotel: @roomInfo.room_count &nbsp; &nbsp; Hotel Chain: @roomInfo.chainname</div>
                            <div class="description">Hotel description: @roomInfo.description </div>
                            <div class="room-capacity">Room Number: @roomInfo.roomnumber &nbsp; &nbsp; Room Capacity: @roomInfo.capacity &nbsp; &nbsp; Room View: @roomInfo.view</div>
                            <div class="room-amenities">Room Amenities: @ViewBag.roomAmenities[@roomInfo.roomnumber]</div>
                        </div>

                        <div class="button-region">
                            <button class="book-button">Book Room</button>
                        </div>
                    </div>

                </div>
            </div>
        }

        @* <div class="search-result">
            <img class="hotel-image" src="https://t3.ftcdn.net/jpg/10/22/24/80/360_F_1022248039_7LDxHRi3Mlt9BK3wzLBUGZp9XAO1gt2s.jpg" />
            <div class="info-holder">
                <div class="main-info">
                    <div class="hotel-name">HOTEL NAME</div>
                    <div class="stars">67 ⭐</div>
                    <div class="price-range">420$-4200$</div>
                </div>

                <div class="line-break"></div>

                <div class="result-body-holder">
                    <div class="other-info">
                        <div class="address">Address: Earth oewuhcowehuwehoiwnxowibxowxbnoiwenxioewxn</div>
                        <div class="total-capacity-chain">6969 rooms, chain chain chain chain</div>
                        <div class="description">blah blah blah blah blah blah blah blah blah blah blah blah </div>
                        <div class="room-capacity">Room Capacity: 67 67</div>
                        <div class="room-view">Room View: rocks</div>
                        <div class="room-amenities">Room Amenities: funny stuff</div>
                    </div>

                    <div class="button-region">

                        <button class="book-button">Book Room</button>
                    </div>
                </div>

            </div>
        </div> *@

    </div>

    @* set up ui functionality for search results and booking rooms *@
    <script>
        let searchResults = document.getElementsByClassName("search-result");
        let overlay = document.querySelector(".form-overlay");

        for (let i = 0; i < searchResults.length; i++){
            let bookButton = searchResults[i].querySelector(".book-button");

            let hotelName = searchResults[i].getAttribute("hotel-name");
            let capacity = searchResults[i].getAttribute("capacity");
            let hotelId = searchResults[i].getAttribute("hotel-id");
            let roomNumber = searchResults[i].getAttribute("room-number");
            let price = searchResults[i].getAttribute("price");

            bookButton.onclick = function(){
                overlay.style.display = "block";
                overlay.querySelector(".booking-hotel-info").innerHTML = "Hotel Name: " + hotelName + "&nbsp; &nbsp; Capacity: " + capacity + "&nbsp; &nbsp; Room Number: " + roomNumber + "<br> price: " + price + "$ / day";
                overlay.querySelector(".hotel-id-input-holder").setAttribute("value", hotelId);
                overlay.querySelector(".room-number-input-holder").setAttribute("value", roomNumber);
            }
        }

        let closeButton = document.querySelector(".close-button");
        closeButton.onclick = function(){
            overlay.style.display = "none";
        }
    </script>

</body>